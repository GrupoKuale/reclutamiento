                                <label t-out="o.actual_date"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Nombre Completo:</td>
                            <td colspan="3">
                                <label t-out="o.partner_name"></label>
                                <label t-out="o.last_name"></label>
                                <label t-out="o.last_name2"></label>
                            </td>
                        </tr>
