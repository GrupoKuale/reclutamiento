                            <td>Tipo de vialidad:</td>
                            <td>
                                <label t-out="o.type_road"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Numero exterior:</td>
                            <td>
                                <label t-out="o.exterior_number"></label>
                            </td>
                            <td>Número interior:</td>
                            <td>
                                <label t-out="o.interior_number"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Colonia:</td>
                            <td colspan="3">
                                <label t-out="o.colony"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Municipio y Estado:</td>
                            <td colspan="3">
                                <label t-out="o.municipality"></label>,
                                <label t-out="o.state_id.name"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Código Postal:</td>
                            <td colspan="3">
                                <label t-out="o.postal_code"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Entre calles:</td>
                            <td colspan="3">
                                <label t-out="o.between_streets"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Referencias adicionales:</td>
                            <td colspan="3">
                                <label t-out="o.additional_ref"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Características del domicilio:</td>
                            <td colspan="3">
                                <label t-out="o.address_details"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Teléfono fijo y celular:</td>
                            <td>
                                Tel.
                                <label t-out="o.desk_phone"></label>
                            </td>
                            <td></td>
                            <td>
                                Cel.
                                <label t-out="o.partner_mobile"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>Correo electrónico</td>
                            <td colspan="3">
                                <label t-out="o.email_from"></label>
                            </td>
                        </tr>
                        <tr>
                            <td>¿Padeces de alguna enfermedad crónica?</td>
                            <td>
                                <t t-if="o.has_chronic_disease == 'yes'">
                                    Si
                                </t>
                                <t t-else="">
                                    No
                                </t>
                            </td>
                            <td colspan="2">
                                <t t-if="o.has_chronic_disease == 'yes'">
                                    ¿Cuál?
                                    <label t-out="o.chronic_disease"></label>
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <td>¿Cómo te enteraste de la oferta laboral?</td>
                            <td colspan="3">
                                Amistad
                            </td>
                        </tr>
