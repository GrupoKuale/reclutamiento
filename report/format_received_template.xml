<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="formatReceived">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t>
                    <t t-call="reclutamiento__kuale.body_Received"/>
                </t>
            </t>
        </t>
    </template>
    <template id="body_Received">
        <t t-call="web.external_layout">
            <div class="page" style="margin-top: 0cm; margin-right: 3cm; margin-bottom: 2.5cm; margin-left: 3cm;">
                <t t-if="o.body_temp">
                    <div t-out="o.body_temp"/>
                </t>
                <t t-else="">
                    <p>El formato de reglamento no se pudo generar.</p>
                </t>
            </div>
        </t>
    </template>

