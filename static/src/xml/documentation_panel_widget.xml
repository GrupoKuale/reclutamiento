<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="reclutamiento__kuale.DocumentationPanelWidget" owl="1">
<style>
    .o_field_documentation_panel_widget {
        width: 100% !important;
        display: block !important;
        min-width: 0 !important;
    }
</style>
<div style="padding:4px 0; font-family:inherit; width:100%; box-sizing:border-box;">

    <!-- Alerta escáner no disponible — mensaje dinámico del servidor -->
    <t t-if="state.scannerOk === false">
        <div class="alert alert-warning mb-3" style="font-size:12px; padding:8px 12px;">
            <i class="fa fa-exclamation-triangle me-1"/>
            <strong>Escáner no detectado.</strong>
            <t t-if="state.scannerMsg">
                <span style="margin-left:4px;"><t t-esc="state.scannerMsg"/></span>
            </t>
            <t t-else="">
                <span style="margin-left:4px;">Verifique que el escáner esté conectado por USB y encendido.</span>
            </t>
        </div>
    </t>

    <!-- Escáner OK — mostrar dispositivo detectado -->
    <t t-if="state.scannerOk === true and state.scannerDev">
        <div class="alert alert-success mb-3" style="font-size:12px; padding:6px 12px;">
            <i class="fa fa-check-circle me-1"/>
            <strong>Escáner listo:</strong>
            <span style="margin-left:4px; font-family:monospace;"><t t-esc="state.scannerDev"/></span>
        </div>
    </t>

    <!-- Encabezado progreso -->
    <div class="d-flex align-items-center justify-content-between px-3 py-2 mb-3"
         style="background:#f8f9fa; border-radius:8px; border:1px solid #dee2e6;">
        <div>
            <span style="font-weight:700; font-size:13px; color:#2c3e50;">📋 Documentación de contratación</span><br/>
            <small class="text-muted"><t t-esc="confirmedCount"/> / <t t-esc="totalCount"/> confirmados</small>
        </div>
        <button t-if="state.scannerOk" 
                t-on-click="onScanAll"
                t-att-disabled="state.scanningId !== null"
                style="background:#2980b9; color:#fff; border:none; border-radius:999px;
                    padding:6px 16px; font-size:12px; font-weight:700; cursor:pointer;
                    margin-left:12px;">
            🗂️ Escaneo múltiple
        </button>
        <div style="width:150px; text-align:right;">
            <div style="background:#e9ecef; border-radius:99px; height:8px; overflow:hidden;">
                <div t-attf-style="width:#{progressPercent}%; height:100%; background:#27ae60;
                                   border-radius:99px; transition:width .4s;"/>
            </div>
            <small class="text-muted"><t t-esc="progressPercent"/>%</small>
        </div>
    </div>

    <!-- Cargando -->
    <t t-if="state.loading">
        <div class="text-center py-4"><i class="fa fa-spinner fa-spin fa-2x text-muted"/></div>
    </t>

    <!-- Layout: barra vertical izquierda + lista derecha -->
    <t t-if="!state.loading">
        <div style="display:flex; align-items:flex-start;">

            <!-- Barra de progreso vertical -->
            <div style="flex:0 0 44px; display:flex; flex-direction:column;
                        align-items:center; padding-top:14px; position:relative;">
                <!-- Línea de fondo -->
                <div style="position:absolute; top:28px; bottom:28px; left:50%;
                            width:2px; background:#dee2e6; transform:translateX(-50%); z-index:0;"/>
                <t t-foreach="state.docs" t-as="doc" t-key="'vp_' + doc.id">
                    <div t-attf-style="
                             width:28px; height:28px; border-radius:50%;
                             background:#{stateColor(doc.state)};
                             display:flex; align-items:center; justify-content:center;
                             font-size:11px; font-weight:700; color:white;
                             z-index:1; box-shadow:0 1px 4px rgba(0,0,0,.15);
                             transition:background .3s; flex-shrink:0;"
                         t-att-title="doc.label + ' — ' + stateLabel(doc.state)">
                        <t t-esc="stateIcon(doc.state)"/>
                    </div>
                    <t t-if="!doc_last">
                        <div style="width:2px; height:40px; background:transparent;"/>
                    </t>
                </t>
            </div>

            <!-- Lista de documentos -->
            <div style="flex:1; min-width:0;">
                <t t-foreach="state.docs" t-as="doc" t-key="'row_' + doc.id">
                    <div t-attf-style="
                             display:flex; align-items:center; gap:10px; padding:10px 12px;
                             border-left:3px solid #{stateColor(doc.state)};
                             background:#{doc.state === 'confirmed' ? '#f0fdf4' :
                                          doc.state === 'scanned'   ? '#fffbeb' : '#fff'};
                             border-bottom:1px solid #f0f0f0; min-height:52px;
                             transition:background .2s;">

                        <!-- Nombre + sub-info -->
                        <div style="flex:1; min-width:0;">
                            <div style="font-weight:600; font-size:13px; color:#2c3e50;
                                        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                <t t-esc="doc.label"/>
                            </div>
                            <div style="font-size:11px; color:#95a5a6; margin-top:2px;">
                                <t t-if="doc.doc_name">
                                    <i class="fa fa-file-pdf-o me-1" style="color:#e74c3c;"/>
                                    <t t-esc="doc.doc_name"/>
                                    <t t-if="doc.migrated">
                                        <span style="margin-left:5px; padding:1px 5px; border-radius:99px;
                                                     background:#3498db; color:white; font-size:9px;">Migrado</span>
                                    </t>
                                </t>
                                <t t-else="">
                                    <span style="font-style:italic; color:#bdc3c7;">Sin archivo</span>
                                </t>
                            </div>
                        </div>

                        <!-- Badge estado -->
                        <span t-attf-style="padding:2px 7px; border-radius:99px; font-size:10px;
                                  font-weight:700; white-space:nowrap; flex-shrink:0;
                                  background:#{stateColor(doc.state)}22; color:#{stateColor(doc.state)};"
                              t-esc="stateLabel(doc.state)"/>

                        <!-- Acciones -->
                        <div class="d-flex gap-1 align-items-center" style="flex-shrink:0;">

                            <!-- Escanear -->
                            <t t-if="doc.state === 'pending'">
                                <button t-attf-class="btn btn-sm #{state.scanningId === doc.id ? 'btn-secondary' : 'btn-primary'}"
                                        style="font-size:11px; padding:3px 9px; font-weight:600;"
                                        t-on-click="() => this.onScan(doc)"
                                        t-att-disabled="state.scanningId !== null">
                                    <t t-if="state.scanningId === doc.id">
                                        <i class="fa fa-spinner fa-spin me-1"/>Escaneando...
                                    </t>
                                    <t t-else=""><i class="fa fa-print me-1"/>Escanear</t>
                                </button>
                            </t>

                            <!-- Ver (ojo) -->
                            <t t-if="doc.attachment_id">
                                <button class="btn btn-sm btn-outline-secondary"
                                        style="padding:3px 7px;" title="Ver documento"
                                        t-on-click="() => this.onPreview(doc)">
                                    <i class="fa fa-eye"/>
                                </button>
                            </t>

                            <!-- Quitar (✕) -->
                            <t t-if="doc.attachment_id and doc.state !== 'confirmed'">
                                <button class="btn btn-sm btn-outline-danger"
                                        style="padding:3px 7px;" title="Quitar documento"
                                        t-on-click="() => this.onRemove(doc)">
                                    <i class="fa fa-times"/>
                                </button>
                            </t>

                            <!-- Confirmar -->
                            <t t-if="doc.state === 'scanned'">
                                <button class="btn btn-sm btn-success"
                                        style="font-size:11px; padding:3px 9px; font-weight:600;"
                                        t-on-click="() => this.onConfirm(doc)">
                                    <i class="fa fa-check me-1"/>Confirmar
                                </button>
                            </t>

                            <!-- Ya confirmado -->
                            <t t-if="doc.state === 'confirmed'">
                                <span style="color:#27ae60; font-size:16px; font-weight:700;">✔</span>
                            </t>

                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</div>
</t>
</templates>