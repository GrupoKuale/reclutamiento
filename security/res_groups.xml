<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rol_employees_permissions" model="ir.module.category">
             <field name="name">Administracion de roles</field>
            <field name="sequence">10</field>
        </record>

        <!-- ===================== GUÍAS ===================== -->
        <record id="group_guias_entrenamiento" model="res.groups">
            <field name="name">Guías en Entrenamiento</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Solo lectura en productos; puede crear órdenes de compra pero no autorizarlas</field>
        </record>

        <record id="group_guias_generales" model="res.groups">
            <field name="name">Guías Generales</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Solo sus candidatos; mueve entre Primera entrevista y Segunda entrevista</field>
            <field name="implied_ids" eval="[(4, ref('group_guias_entrenamiento'))]"/>
        </record>

        <record id="group_guias_foraneos" model="res.groups">
            <field name="name">Guías Foráneos</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Solo sus candidatos; puede mover por todas las etapas del pipeline</field>
            <field name="implied_ids" eval="[(4, ref('group_guias_entrenamiento'))]"/>
        </record>

        <!-- ===================== DH - Desarrollo Humano ===================== -->
        <record id="group_dh_access" model="res.groups">
            <field name="name">Desarrollo Humano - Auxiliar (DH)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel auxiliar de Desarrollo Humano</field>
        </record>

        <record id="group_dh_gerente" model="res.groups">
            <field name="name">Desarrollo Humano - Gerente (DH)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel gerente de Desarrollo Humano; hereda permisos de auxiliar</field>
            <field name="implied_ids" eval="[(4, ref('group_dh_access'))]"/>
        </record>

        <record id="group_dh_director" model="res.groups">
            <field name="name">Desarrollo Humano - Director (DH)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel director de Desarrollo Humano; hereda permisos de gerente</field>
            <field name="implied_ids" eval="[(4, ref('group_dh_gerente'))]"/>
        </record>

        <!-- ===================== LGP - La Gente Primero ===================== -->
        <record id="group_lgp_access" model="res.groups">
            <field name="name">La Gente Primero - Auxiliar (LGP)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel auxiliar de La Gente Primero</field>
        </record>

        <record id="group_lgp_gerente" model="res.groups">
            <field name="name">La Gente Primero - Gerente (LGP)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel gerente de La Gente Primero; hereda permisos de auxiliar</field>
            <field name="implied_ids" eval="[(4, ref('group_lgp_access'))]"/>
        </record>

        <record id="group_lgp_director" model="res.groups">
            <field name="name">La Gente Primero - Director (LGP)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel director de La Gente Primero; hereda permisos de gerente</field>
            <field name="implied_ids" eval="[(4, ref('group_lgp_gerente'))]"/>
        </record>

        <!-- ===================== PXC - Pasión por el Cliente ===================== -->
        <record id="group_pxc_access" model="res.groups">
            <field name="name">Pasión por el Cliente - Auxiliar (PXC)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel auxiliar de Pasión por el Cliente</field>
        </record>

        <record id="group_pxc_gerente" model="res.groups">
            <field name="name">Pasión por el Cliente - Gerente (PXC)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel gerente de Pasión por el Cliente; hereda permisos de auxiliar</field>
            <field name="implied_ids" eval="[(4, ref('group_pxc_access'))]"/>
        </record>

        <record id="group_pxc_director" model="res.groups">
            <field name="name">Pasión por el Cliente - Director (PXC)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel director de Pasión por el Cliente; hereda permisos de gerente</field>
            <field name="implied_ids" eval="[(4, ref('group_pxc_gerente'))]"/>
        </record>

        <!-- ===================== OR - Optimización de Recursos ===================== -->
        <record id="group_or_auxiliar" model="res.groups">
            <field name="name">Optimización de Recursos - Auxiliar (OR)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel auxiliar de Optimización de Recursos; acceso a contabilidad</field>
        </record>

        <record id="group_or_gerente" model="res.groups">
            <field name="name">Optimización de Recursos - Gerente (OR)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel gerente de Optimización de Recursos; hereda permisos de auxiliar</field>
            <field name="implied_ids" eval="[(4, ref('group_or_auxiliar'))]"/>
        </record>

        <record id="group_or_director" model="res.groups">
            <field name="name">Optimización de Recursos - Director (OR)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel director de Optimización de Recursos; hereda permisos de gerente</field>
            <field name="implied_ids" eval="[(4, ref('group_or_gerente'))]"/>
        </record>

        <!-- ===================== CA - Conservación de Activos ===================== -->
        <record id="group_ca_auxiliar" model="res.groups">
            <field name="name">Conservación de Activos - Auxiliar (CA)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel auxiliar de Conservación de Activos</field>
        </record>

        <record id="group_ca_gerente" model="res.groups">
            <field name="name">Conservación de Activos - Gerente (CA)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel gerente de Conservación de Activos; hereda permisos de auxiliar</field>
            <field name="implied_ids" eval="[(4, ref('group_ca_auxiliar'))]"/>
        </record>

        <record id="group_ca_director" model="res.groups">
            <field name="name">Conservación de Activos - Director (CA)</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel director de Conservación de Activos; hereda permisos de gerente</field>
            <field name="implied_ids" eval="[(4, ref('group_ca_gerente'))]"/>
        </record>

        <!-- ===================== DIRECCIÓN / CONSEJO ===================== -->
        <record id="group_direccion" model="res.groups">
            <field name="name">Dirección / Consejo</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">CEO y socios: acceso de solo lectura a Contabilidad kuale</field>
            <field name="implied_ids" eval="[(4, ref('account.group_account_readonly'))]"/>
        </record>

        <!-- ===================== ENLACE ===================== -->
        <record id="group_enlace_auxiliar" model="res.groups">
            <field name="name">Enlace - Auxiliar</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel auxiliar de Enlace</field>
        </record>

        <record id="group_enlace_gerente" model="res.groups">
            <field name="name">Enlace - Gerente</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel gerente de Enlace; hereda permisos de auxiliar</field>
            <field name="implied_ids" eval="[(4, ref('group_enlace_auxiliar'))]"/>
        </record>

        <record id="group_enlace_director" model="res.groups">
            <field name="name">Enlace - Director</field>
            <field name="category_id" ref="rol_employees_permissions"/>
            <field name="comment">Nivel director de Enlace; hereda permisos de gerente</field>
            <field name="implied_ids" eval="[(4, ref('group_enlace_gerente'))]"/>
        </record>

    </data>
</odoo>
