<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_employee_request_uniform_form" model="ir.ui.view">
            <field name="name">employee.request.uniform.form</field>
            <field name="model">reclutamiento__kuale.employee.request.uniform</field>
            <field name="arch" type="xml">
                <form string="Solicitud de uniforme">
                    <sheet>
                        <group>
                            <field name="item"/>
                            <field name="size"/>
                            <field name="uniformRequestReason"/>
                            <field name="requestId" context="{'default_uniformRequestId': active_id}">
                                <tree>
                                    <field name="requestedBy"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_employee_request_uniform_tree" model="ir.ui.view">
            <field name="name">employee.request.uniform.tree</field>
            <field name="model">reclutamiento__kuale.employee.request.uniform</field>
            <field name="arch" type="xml">
                <tree string="Solcitudes de uniforme">
                    <field name="item"/>
                    <field name="size"/>
                    <field name="uniformRequestReason"/>
                    <field name="requestId"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_employee_request_uniform_search" model="ir.ui.view">
            <field name="name">employee.request.uniform.search</field>
            <field name="model">reclutamiento__kuale.employee.request.uniform</field>
            <field name="arch" type="xml">
                <search string="Buscar solcitudes de uniforme">
                    <filter name="filter_item" string="Prenda" domain="[('item', '!=', False)]"/>
                    <filter name="filter_size" string="Tamaño" domain="[('size', '!=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_employee_request_uniform" model="ir.actions.act_window">
            <field name="name">Solicitudes de uniforme</field>
            <field name="res_model">reclutamiento__kuale.employee.request.uniform</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_employee_request_uniform_tree"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Crea la primera solicitud de uniforme.
                </p>
            </field>
        </record>

    </data>
</odoo>