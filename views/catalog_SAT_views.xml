<odoo>
    <!--TIPOS DE CONTRATOS-->
    <record id="catalog_sat_type_contract_action" model="ir.actions.act_window">
        <field name="name">Tipos de contratos</field>
        <field name="res_model">catalog_sat.type_contract</field>
        <field name="view_mode">tree</field>
    </record>
    <record id="catalog_sat_type_contract_view_tree" model="ir.ui.view">
        <field name="model">catalog_sat.type_contract</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
