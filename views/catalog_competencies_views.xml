<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="reclutamiento__kuale_competencies_type_action" model="ir.actions.act_window">
        <field name="name">Competencias</field>
        <field name="res_model">reclutamiento__kuale.competencies_type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="employee_competence_level_view_tree" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.competencies_level.tree</field>
        <field name="model">reclutamiento__kuale.competencies_level</field>
        <field name="arch" type="xml">
            <tree string="Niveles" class="o_skill_level_tree" editable="bottom">
                <field name="name"/>
                <field name="level_progress" widget="progressbar" options="{'editable': true}"/>
                <field name="default_level" widget="boolean_toggle_load"/>
            </tree>
        </field>
    </record>

    <record id="employee_competence_view_tree" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.competencies.tree</field>
        <field name="model">reclutamiento__kuale.competencies</field>
        <field name="arch" type="xml">
            <tree string="Niveles">
                <field name="name"/>
                <field name="competency_type_id"/>
            </tree>
        </field>
    </record>

    <record id="employee_competence_level_view_form" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.competencies_level.form</field>
        <field name="model">reclutamiento__kuale.competencies_level</field>
        <field name="arch" type="xml">
            <form string="Nivel">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="level_progress" string="Progress (%)"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="reclutamiento__kuale_competencies_view_form" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.competencies.form</field>
        <field name="model">reclutamiento__kuale.competencies</field>
        <field name="arch" type="xml">
            <form string="Competencias">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="competency_type_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="reclutamiento__kuale_competencies_view_search" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.competencies.view.search</field>
        <field name="model">reclutamiento__kuale.competencies</field>
        <field name="arch" type="xml">
            <search string="Buscar competencias">
                <field name="name" string="Competencia"/>
                <field name="competency_type_id" string="Tipo de competencia"/>
                <separator/>
                <group expand="0" string="Group By...">
                    <filter string="Tipo de competencia" name="group_competency_type_id" domain="[]" context="{'group_by':'competency_type_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="reclutamiento__kuale_competencies_type_view_tree" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.competencies_type.tree</field>
        <field name="model">reclutamiento__kuale.competencies_type</field>
        <field name="arch" type="xml">
            <tree string="Tipo de competencias">
                <field name="name"/>
                <field name="competencies_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="reclutamiento__kuale_competencies_type_view_form" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.competencies_type.form</field>
        <field name="model">reclutamiento__kuale.competencies_type</field>
        <field name="arch" type="xml">
            <form string="Tipo de competencia">
                <field name="id" invisible="1"/>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Tipo de competencia"/>
                        <h1>
                            <field name="name" placeholder="e.g. PowerBI admin" required="True"/>
                        </h1>
                    </div>
                    <group string="Competencias">
                    </group>
                    <field name="competencies_ids" nolabel="1" context="{'default_competency_type_id': id}">
                        <tree editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                        </tree>
                    </field>
                    <group string="Niveles">
                    </group>
                    <field name="competencies_level_ids" nolabel="1" widget="auto_save_skill_type" context="{'default_competency_type_id': id}"/>
                </sheet>
            </form>
        </field>
    </record>


</odoo>















