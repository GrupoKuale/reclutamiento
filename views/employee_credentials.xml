<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_employee_form_inherit_credentials" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.credentials</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <!-- Botón en el notebook para asignar credenciales móviles -->
                <xpath expr="//notebook" position="inside">
                    <page string="Mobile App Credentials">
                        <group>
                            <button name="open_user_creation_wizard" type="object" string="Configurar Usuario Móvil" class="oe_highlight"/>
                        </group>
                    </page>
                </xpath>
                
                <!-- Botón en el header para mayor visibilidad -->
                <xpath expr="//header" position="inside">
                    <button name="open_user_creation_wizard" type="object" string="Asignar Credenciales Móviles" class="oe_highlight"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
