<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_zkteco_log_form" model="ir.ui.view">
        <field name="name">zkteco.log.form</field>
        <field name="model">reclutamiento__kuale.zkteco_log</field>
        <field name="arch" type="xml">
            <form string="Registro de Asistencia Zkteco">
                <sheet>
                    <group>
                        <field name="device_employee_id"/>
                        <field name="employee_id" readonly="1"/>
                        <field name="action"/>
                        <field name="attendance_type"/>
                        <field name="punching_time"/>
                    </group>
                    <group>
                        <field name="work_location"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_zkteco_log_tree" model="ir.ui.view">
        <field name="name">zkteco.log.tree</field>
        <field name="model">reclutamiento__kuale.zkteco_log</field>
        <field name="arch" type="xml">
            <tree string="Registros de Asistencia Zkteco">
                <field name="employee_id"/>
                <field name="action"/>
                <field name="attendance_type"/>
                <field name="punching_time"/>
                <field name="migrated"/>
            </tree>
        </field>
    </record>

    <record id="action_zkteco_log" model="ir.actions.act_window">
        <field name="name">Registros de Asistencia Zkteco</field>
        <field name="res_model">reclutamiento__kuale.zkteco_log</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>
                Gestiona los registros de asistencia del dispositivo biométrico Zkteco.
            </p>
        </field>
    </record>


    <!-- CRON JOB -->
     <record id="ir_cron_migrate_zkteco_to_attendance" model="ir.cron">
            <field name="name">Migrar ZKTECO Log a Asistencia</field>
            <field name="model_id" ref="model_reclutamiento__kuale_zkteco_log"/>
            <field name="state">code</field>
            <field name="code">model.migrate_information()</field>
            <field name="user_id" ref="base.user_admin"/>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="nextcall">2024-12-05 03:30:00</field>
        </record>

</odoo>