<odoo>
    <record id="zk_biometric_confirm_wizard_form" model="ir.ui.view">
        <field name="name">zk.biometric.confirm.wizard.form</field>
        <field name="model">zk.biometric.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirmar verificación" class="o_dialog_sm">
                <sheet>
                    <div style="text-align: center; padding: 24px 0;">
                        <h3 style="margin-bottom: 8px;">Huella registrada correctamente</h3>
                        <p style="color: #6c757d; margin: 0;">Confirma para finalizar el proceso.</p>
                    </div>
                </sheet>
                <footer>
                    <button string="Aceptar" name="action_confirm"
                            type="object" class="btn btn-success"/>
                    <button string="Cancelar" special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>