<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_applicant_view_request_documentation" model="ir.ui.view">
        <field name="name">hr.applicant.request_documentation</field>
        <field name="model">hr_applicant_doc</field>
        <field name="arch" type="xml">
            <form string="Solicitar Documentación">
                <sheet>
                    <group string="Información de la cita">
                        <field name="datetimeSession" string="Fecha y Hora"/>
                        <field name="place" string="Lugar"/>
                        <field name="contactSession" string="Contacto"/>
                        <field name="workDate" string="Fecha de inicio"/>
                        <field name="duration" string="Duración de la contratación"/>
                    </group>
                    <group string="Formato a enviar">
                        <field name="format_id" string="Formato"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Enviar" type="object" name="action_send" class="btn btn-primary"/>
                    <button string="Descartar" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Vista catálogo de formatos -->
    <record id="hr_applicant_doc_format_form" model="ir.ui.view">
        <field name="name">hr.applicant.doc.format.form</field>
        <field name="model">hr.applicant.doc.format</field>
        <field name="arch" type="xml">
            <form string="Formato de contratación">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                    <separator string="Archivo PDF (Formato de contratación GK)"/>
                    <group>
                        <field name="pdf_file" widget="binary" filename="pdf_filename"
                               string="Archivo PDF"/>
                        <field name="pdf_filename" invisible="1"/>
                    </group>
                    <separator string="Archivo Word (Contrato de trabajo)"/>
                    <group>
                        <field name="docx_file" widget="binary" filename="docx_filename"
                               string="Archivo Word (.docx)"/>
                        <field name="docx_filename" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_applicant_doc_format_tree" model="ir.ui.view">
        <field name="name">hr.applicant.doc.format.tree</field>
        <field name="model">hr.applicant.doc.format</field>
        <field name="arch" type="xml">
            <tree string="Formatos de contratación">
                <field name="name"/>
                <field name="pdf_filename" string="Archivo PDF"/>
                <field name="docx_filename" string="Archivo Word"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="hr_applicant_doc_format_action" model="ir.actions.act_window">
        <field name="name">Formatos de contratación</field>
        <field name="res_model">hr.applicant.doc.format</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>