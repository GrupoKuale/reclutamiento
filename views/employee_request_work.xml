<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_employee_request_work_form" model="ir.ui.view">
            <field name="name">employee.request.work.form</field>
            <field name="model">reclutamiento__kuale.employee.request.work</field>
            <field name="arch" type="xml">
                <form string="Solicitud de trabajo">
                    <sheet>
                        <group>
                            <field name="type"/>
                            <field name="requestId" context="{'default_workRequestId': active_id}">
                                <tree>
                                    <field name="requestedBy"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_employee_request_work_tree" model="ir.ui.view">
            <field name="name">employee.request.work.tree</field>
            <field name="model">reclutamiento__kuale.employee.request.work</field>
            <field name="arch" type="xml">
                <tree string="Solicitudes de trabajo">
                    <field name="type"/>
                    <field name="requestId"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_employee_request_work_search" model="ir.ui.view">
            <field name="name">employee.request.work.search</field>
            <field name="model">reclutamiento__kuale.employee.request.work</field>
            <field name="arch" type="xml">
                <search string="Buscar solicitudes de trabajo">
                    <filter name="filter_type" string="Tipo" domain="[('type', '!=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_employee_request_work" model="ir.actions.act_window">
            <field name="name">Solicitudes de trabajo</field>
            <field name="res_model">reclutamiento__kuale.employee.request.work</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_employee_request_work_tree"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Crea la primera solicitud de trabajo.
                </p>
            </field>
        </record>

    </data>
</odoo>