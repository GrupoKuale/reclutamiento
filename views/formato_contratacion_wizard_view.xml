<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_formato_contratacion_wizard_form" model="ir.ui.view">
        <field name="name">reclutamiento__kuale.formato_contratacion_wizard.form</field>
        <field name="model">reclutamiento__kuale.formato_contratacion_wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Formato de Contratación">
                <sheet>
                    <field name="applicant_id"       invisible="1"/>
                    <field name="formatos_wizard_id" invisible="1"/>

                    <div style="text-align:center; padding:8px 0 16px;">
                        <h4 style="margin:8px 0 4px; color:#0097a7;">
                            Formato de Contratación GK
                        </h4>
                        <p style="color:#666; font-size:13px; margin:0;">
                            Selecciona el formato base y genera el PDF.
                        </p>
                    </div>

                    <group>
                        <field name="formato_base_id"
                               options="{'no_create': True, 'no_open': True}"
                               string="Formato base"/>
                    </group>

                    <div style="background:#f0f9ff; border:1px solid #bae6fd;
                                border-radius:8px; padding:10px 14px; margin-top:8px;
                                font-size:12px; color:#0369a1;">
                        <strong>Datos que se incluirán:</strong><br/>
                        Nombre completo, edad, CURP, NSS, puesto, domicilio,
                        teléfono, correo, cuenta bancaria y beneficiarios.
                    </div>
                </sheet>
                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Generar y descargar PDF"
                            class="btn btn-primary"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancelar"
                            class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>