<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_employee_request_labor_letter_form" model="ir.ui.view">
            <field name="name">employee.request.labor.letter.form</field>
            <field name="model">reclutamiento__kuale.employee.request.labor_letter</field>
            <field name="arch" type="xml">
                <form string="Solicitudes de Carta Laboral">
                    <sheet>
                        <group>
                            <field name="purpose"/>
                            <field name="requestId" context="{'default_labor_letterRequestId': active_id}">
                                <tree>
                                    <field name="requestedBy"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_employee_request_labor_letter_tree" model="ir.ui.view">
            <field name="name">employee.request.labor.letter.tree</field>
            <field name="model">reclutamiento__kuale.employee.request.labor_letter</field>
            <field name="arch" type="xml">
                <tree string="Solicitudes de Carta Laboral">
                    <field name="purpose"/>
                    <field name="requestId"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_employee_request_labor_letter_search" model="ir.ui.view">
            <field name="name">employee.request.labor.letter.search</field>
            <field name="model">reclutamiento__kuale.employee.request.labor_letter</field>
            <field name="arch" type="xml">
                <search string="Buscar solicitudes de Carta Laboral">
                    <filter name="filter_purpose" string="Propósito" domain="[('purpose', '!=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_employee_request_labor_letter" model="ir.actions.act_window">
            <field name="name">Solicitudes de Carta Laboral</field>
            <field name="res_model">reclutamiento__kuale.employee.request.labor_letter</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_employee_request_labor_letter_tree"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Crea la primera solicitud de Carta Laboral.
                </p>
            </field>
        </record>
    </data>
</odoo>