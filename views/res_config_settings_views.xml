<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_recruitment_signup" 
            model="ir.ui.view">
        <field name="name">res.config.settings.recruitment.signup</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">
                <block title="Correo de Bienvenida" name="correo_bienvenida">
                    <setting 
                        string="Plantilla de bienvenida"
                        help="Plantilla que se enviará al crear un nuevo usuario">
                        <field name="signup_email_template_id"
                               domain="[('model', '=', 'res.users')]"/>
                    </setting>
                    <setting 
                        string="Plantilla de cambio de contraseña"
                        help="Plantilla que se enviará al resetear la contraseña">
                        <field name="reset_password_email_template_id"
                               domain="[('model', '=', 'res.users')]"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>