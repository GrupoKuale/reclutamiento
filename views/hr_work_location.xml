<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_work_location_form_custom" model="ir.ui.view">
            <field name="name">hr.work.location.form.custom</field>
            <field name="model">hr.work.location</field>
            <field name="inherit_id" ref="hr.hr_work_location_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="latitude"/>
                    <field name="longitude"/>
                    <field name="allowed_distance"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
