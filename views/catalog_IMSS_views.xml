<odoo>
    <!--ZONA DE SALARIOS-->
    <record id="catalog_imss_salary_zone_action" model="ir.actions.act_window">
        <field name="name">Zona de salario</field>
        <field name="res_model">catalog_imss.salary_zone</field>
        <field name="view_mode">tree</field>
    </record>
    <record id="catalog_imss_salary_zone_view_tree" model="ir.ui.view">
        <field name="model">catalog_imss.salary_zone</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="effective_date"/>
                <field name="wage_zone_a"/>
                <field name="wage_zone_b"/>
                <field name="wage_zone_c"/>
            </tree>
        </field>
    </record>
