<odoo>
    <data>
        <record id="reclutamiento_kuale_city_tree_view" model="ir.ui.view">
            <field name="name">reclutamiento__kuale.city.view.tree</field>
            <field name="model">reclutamiento__kuale.city</field>
            <field name="arch" type="xml">
                <tree string="Ciudades">
                    <field name="code" />
                    <field name="settlement" />
                    <field name="settlement_type" />
                    <field name="municipality" />
                    <field name="city" />
                    <field name="state" />
                </tree>
            </field>
        </record>
        <record id="reclutamiento_kuale_city_form_view" model="ir.ui.view">
            <field name="name">reclutamiento__kuale.city.view.form</field>
            <field name="model">reclutamiento__kuale.city</field>
            <field name="arch" type="xml">
                <form string="Ciudades">
                    <sheet>
                        <group>
                            <group>
                                <field name="code" />
                                <field name="settlement" />
                                <field name="settlement_type" />
                                <field name="municipality" />
                                <field name="city" />
                                <field name="state" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="reclutamiento__kuale_city_action" model="ir.actions.act_window">
            <field name="name">Direcciones </field>
            <field name="res_model">reclutamiento__kuale.city</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear nuevo registro
                </p>
            </field>
        </record>
    </data>
</odoo>