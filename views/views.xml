        <field name="active" eval="True"/>
        <field name="groups_id" eval="[(6, 0, [ref('hr_recruitment.group_hr_recruitment_user')])]"/>
        </record>

        <record id="hr_recruitment.menu_hr_recruitment_config_jobs" model="ir.ui.menu">
