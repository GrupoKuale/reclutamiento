<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Plantilla de correo para Employee Request -->
        <record id="email_template_employee_request" model="mail.template">
            <field name="name">Employee Request Notification</field>
            <field name="model_id" ref="model_reclutamiento__kuale_employee_request"/>
            <!--      verify odoo bot or emailing address for system mails   -->
            <field name="email_from">{{object.env['ir.mail_server'].search([], limit=1).smtp_user}}</field>
            <field name="email_to">${(user.email)}</field>
            <field name="subject">New Employee Request: {{object.folio}}</field>
            <field name="body_html" type="html">
                <div style="font-family: 'Arial', sans-serif; color: #333;">
                    <p style="color: #71639e; font-size: 18px;">Hello,</p>
                    <p style="font-size: 16px;">A new employee request has been created with the following details:</p>
                    <br/>
                    <table style="border-collapse: collapse; width: 80%; font-size: 15px; margin: auto;">
                        <tr>
                            <td style="padding: 8px; background-color: #f2f2f2;">
                                <strong>Folio:</strong>
                            </td>
                            <td style="padding: 8px; background-color: #f2f2f2;" t-out="object.folio"/>
                        </tr>
                        <tr>
                            <td style="padding: 8px;">
                                <strong>Type:</strong>
                            </td>
                            <td style="padding: 8px;" t-out="object.requestType"/>
                        </tr>
                        <tr>
                            <td style="padding: 8px; background-color: #f2f2f2;">
                                <strong>Description:</strong>
                            </td>
                            <td style="padding: 8px; background-color: #f2f2f2;" t-out="object.requestDescription"/>
                        </tr>
                        <tr>
                            <td style="padding: 8px;">
                                <strong>Requested by:</strong>
                            </td>
                            <td style="padding: 8px;" t-out="object.requestedBy.name"/>
                        </tr>
                        <tr>
                            <td style="padding: 8px; background-color: #f2f2f2;">
                                <strong>Status:</strong>
                            </td>
                            <td style="padding: 8px; background-color: #f2f2f2;" t-out="object.status"/>
                        </tr>
                    </table>
                    <br/>
                    <p>Please go to employee requests module for more details.</p>
                    <p style="margin-top: 20px;">Best regards,</p>
                    <p style="font-weight: bold;">Odoo System</p>
                </div>
            </field>
        </record>

    </data>
</odoo>