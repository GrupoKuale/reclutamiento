<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Departamento (ligado a la compañía principal) -->
        <record id="department_kuale_demo" model="hr.department">
            <field name="name">Operaciones</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="acronym">OPE</field>
        </record>

        <!-- Ciudad -->
        <record id="city_kuale_demo" model="reclutamiento__kuale.city">
            <field name="code">64000</field>
            <field name="settlement">Centro</field>
            <field name="settlement_type">Colonia</field>
            <field name="municipality">Monterrey</field>
            <field name="city">Monterrey</field>
            <field name="state">Nuevo León</field>
        </record>

        <!-- Catálogos básicos -->
        <record id="schooling_kuale_demo" model="reclutamiento__kuale.schooling">
            <field name="name">Licenciatura</field>
            <field name="description">Licenciatura concluida</field>
        </record>

        <record id="language_kuale_demo" model="reclutamiento__kuale.language">
            <field name="name">Inglés</field>
            <field name="description">Inglés general</field>
        </record>
        <record id="language_level_kuale_demo" model="reclutamiento__kuale.language_level">
            <field name="name">Intermedio</field>
            <field name="level_progress">60</field>
            <field name="language_k_id" ref="language_kuale_demo"/>
        </record>

        <record id="competency_type_kuale_demo" model="reclutamiento__kuale.competencies_type">
            <field name="name">Competencias Técnicas</field>
        </record>
        <record id="competency_kuale_demo" model="reclutamiento__kuale.competencies">
            <field name="name">Atención al cliente</field>
            <field name="sequence">10</field>
            <field name="competency_type_id" ref="competency_type_kuale_demo"/>
        </record>

        <record id="tool_kuale_demo" model="reclutamiento__kuale.tools_knowledge">
            <field name="name">Caja registradora</field>
            <field name="type">tool</field>
            <field name="description">Manejo de caja y cortes</field>
        </record>
        <record id="software_kuale_demo" model="reclutamiento__kuale.tools_knowledge">
            <field name="name">Excel</field>
            <field name="type">software</field>
            <field name="description">Nivel básico</field>
        </record>

        <record id="activity_kuale_demo" model="reclutamiento__kuale.activities">
            <field name="name">Cobro y atención al cliente</field>
            <field name="description">Atender caja, realizar cobros y arqueos.</field>
        </record>

        <record id="experience_kuale_demo" model="reclutamiento__kuale.experience">
            <field name="name">1 año en caja</field>
            <field name="comments">Experiencia mínima en puestos similares</field>
        </record>

        <record id="internal_rel_kuale_demo" model="reclutamiento__kuale.internal_relations">
            <field name="name">Relación con Operaciones</field>
            <field name="description">Coordinación con supervisores</field>
        </record>
        <record id="external_rel_kuale_demo" model="reclutamiento__kuale.external_relations">
            <field name="name">Relación con clientes</field>
            <field name="description">Atención directa al cliente final</field>
        </record>
        <record id="performance_kuale_demo" model="reclutamiento__kuale.performance_standars">
            <field name="name">Exactitud en cortes</field>
            <field name="description">Cortes diarios sin diferencias</field>
        </record>

        <record id="age_kuale_demo" model="reclutamiento__kuale.age">
            <field name="name">25-35</field>
            <field name="description">Rango de edad preferente</field>
        </record>

        <record id="weekday_kuale_demo" model="reclutamiento__kuale.weekdays">
            <field name="name">Lunes</field>
        </record>

        <record id="gender_kuale_demo" model="reclutamiento__kuale.gender">
            <field name="name">Indistinto</field>
        </record>

        <!-- Contrato -->
        <record id="contract_type_kuale_demo" model="reclutamiento__kuale.contract_type">
            <field name="name">Tiempo completo</field>
            <field name="description">Contrato de tiempo completo</field>
            <field name="company_id" ref="base.main_company"/>
        </record>
        <record id="trial_period_kuale_demo" model="reclutamiento__kuale.trial_period">
            <field name="name">Prueba 30 días</field>
            <field name="sequence">10</field>
            <field name="description">Periodo de prueba estándar</field>
            <field name="contract_type_id" ref="contract_type_kuale_demo"/>
        </record>
        <record id="jornada_kuale_demo" model="reclutamiento__kuale.jornada">
            <field name="name">Diurna</field>
            <field name="description">Jornada diurna</field>
            <field name="contract_type_id" ref="contract_type_kuale_demo"/>
        </record>

        <!-- Catálogos de requisición -->
        <record id="shift_kuale_demo" model="reclutamiento__kuale.shifts">
            <field name="name">Matutino</field>
            <field name="description">Turno matutino</field>
        </record>
        <record id="reason_kuale_demo" model="reclutamiento__kuale.requisition_reasons">
            <field name="name">Crecimiento de plantilla</field>
            <field name="description">Apertura de nuevas posiciones</field>
        </record>

        <!-- Producto uniforme -->
        <record id="product_template_uniform_demo" model="product.template">
            <field name="name">Playera Uniforme Demo</field>
            <field name="detailed_type">consu</field>
            <field name="list_price">199.00</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
            <field name="sale_ok">True</field>
            <field name="uniform_type">True</field>
        </record>

        <!-- Vacante -->
        <record id="job_kuale_demo" model="hr.job">
            <field name="name">Cajero(a) Demo</field>
            <field name="name_kuale">Cajero(a) Kuale</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="department_id" ref="department_kuale_demo"/>
            <field name="website_published">True</field>
            <field name="is_published">True</field>
            <field name="is_Parent_Job">True</field>
            <field name="job_position_type">Administrative</field>
            <field name="no_of_recruitment">5</field>
            <field name="contract_type_kuale_id" ref="contract_type_kuale_demo"/>
            <field name="schooling_id" ref="schooling_kuale_demo"/>
            <field name="age_id" ref="age_kuale_demo"/>
            <field name="gender_id" ref="gender_kuale_demo"/>
            <field name="city_Job" ref="city_kuale_demo"/>
            <field name="activities_ids" eval="[(6, 0, [ref('activity_kuale_demo')])]"/>
            <field name="experiences_ids" eval="[(6, 0, [ref('experience_kuale_demo')])]"/>
            <field name="tool_ids" eval="[(6, 0, [ref('tool_kuale_demo')])]"/>
            <field name="software_ids" eval="[(6, 0, [ref('software_kuale_demo')])]"/>
            <field name="competence_ids" eval="[(6, 0, [ref('competency_kuale_demo')])]"/>
            <field name="language_k_ids" eval="[(6, 0, [ref('language_kuale_demo')])]"/>
            <field name="int_rel_ids" eval="[(6, 0, [ref('internal_rel_kuale_demo')])]"/>
            <field name="ext_rel_ids" eval="[(6, 0, [ref('external_rel_kuale_demo')])]"/>
            <field name="perf_st_ids" eval="[(6, 0, [ref('performance_kuale_demo')])]"/>
            <field name="day_ids" eval="[(6, 0, [ref('weekday_kuale_demo')])]"/>
            <field name="days_off2" eval="[(6, 0, [ref('weekday_kuale_demo')])]"/>
        </record>

        <record id="job_garment_kuale_demo" model="reclutamiento__kuale.product_garments">
            <field name="job_id" ref="job_kuale_demo"/>
            <field name="product_template_id" ref="product_template_uniform_demo"/>
            <field name="quantity">2</field>
        </record>

        <!-- Requisición -->
        <record id="requisition_kuale_demo" model="reclutamiento__kuale.requisitions">
            <field name="job_id" ref="job_kuale_demo"/>
            <field name="date_entry">2026-02-01</field>
            <field name="inmediate_job_id" ref="base.user_admin"/>
            <field name="company_id" ref="base.main_company"/>
            <field name="branch_ids" ref="base.main_company"/>
            <field name="department_id" ref="department_kuale_demo"/>
            <field name="gender">indistinct</field>
            <field name="reason_vacancy" ref="reason_kuale_demo"/>
        </record>

        <record id="requisition_detail_kuale_demo" model="reclutamiento__kuale.requisitions_details">
            <field name="requisition_id" ref="requisition_kuale_demo"/>
            <field name="quantity">3</field>
            <field name="quantity_auth">3</field>
            <field name="shift" ref="shift_kuale_demo"/>
            <field name="reason" ref="reason_kuale_demo"/>
            <field name="student">no</field>
        </record>

